{
  "name": "pack-site",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 4444",
    "dev:tunnel": "node scripts/tunnel.mjs ngrok",
    "dev:tunnel:lt": "node scripts/tunnel.mjs localtunnel",
    "dev:payments": "tsx server/index.mjs",
    "build": "tsc --noEmit && vite build",
    "cap:sync:ios": "npx cap sync ios && node scripts/ensureAppleSignInPlugin.mjs",
    "preview": "vite preview --port 4444",
    "seed:pokemon": "node scripts/seedPokemon.js",
    "seed:upgrader-sql": "tsx scripts/generateUpgraderSeed.ts",
    "sync:weights": "vite-node scripts/syncPackWeights.ts",
    "sync:weights:check": "vite-node scripts/syncPackWeights.ts --check",
    "dev:set-balance": "node scripts/setGemBalance.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@capacitor-community/stripe": "^8.1.1",
    "@capacitor/android": "^8.3.4",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/keyboard": "^8.0.3",
    "@supabase/supabase-js": "^2.106.1",
    "@tanstack/react-query": "^5.100.14",
    "@upstash/redis": "^1.38.0",
    "@vercel/node": "^5.8.6",
    "framer-motion": "^12.40.0",
    "micro": "^10.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-is": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "recharts": "^3.8.1",
    "sharp": "^0.34.5",
    "stripe": "^22.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/vite": "^4.1.7",
    "@types/node": "^25.9.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "localtunnel": "^2.0.2",
    "tailwindcss": "^4.1.7",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-node": "^6.0.0"
  }
}
