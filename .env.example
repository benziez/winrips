# Vercel KV (auto-injected when KV is linked to the project)
KV_REST_API_URL=""
KV_REST_API_TOKEN=""

NOWPAYMENTS_API_KEY="your-nowpayments-api-key"
NOWPAYMENTS_API_URL="https://api.nowpayments.io/v1"
# IPN secret from NOWPayments dashboard → Payment Settings (used to verify x-nowpayments-sig)
NOWPAYMENTS_IPN_SECRET="your-nowpayments-ipn-secret"
# Production IPN (public HTTPS). Also sent per-payment when set.
# https://your-domain.com/api/payments/webhook
# NOWPAYMENTS_IPN_CALLBACK_URL="https://your-domain.com/api/payments/webhook"

# Local dev IPN: use ngrok (NOT localtunnel — NOWPayments cannot send bypass headers).
#   brew install ngrok/ngrok/ngrok && ngrok config add-authtoken <token>
#   npm run dev:tunnel
# NOWPAYMENTS_TUNNEL_URL="https://xxxx.ngrok-free.app"
# Webhook: POST https://xxxx.ngrok-free.app/api/payments/webhook

# Dev-only balance override (POST /api/account/balance/dev-set). Use a long random string.
DEV_BALANCE_SECRET="local-dev-balance-secret"
# Same value for the Vite dev UI panel (never commit real secrets):
VITE_DEV_BALANCE_SECRET="local-dev-balance-secret"
